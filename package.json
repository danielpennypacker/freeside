{
  "name": "freeside",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Freeside — a run-from-the-page D&D adventure as a Cloudflare Worker (Hono + D1 + native Web Components).",
  "scripts": {
    "dev": "wrangler dev --var ALLOW_DEV_LOGIN:true",
    "deploy": "wrangler deploy",
    "build:adventure": "tsx scripts/build-adventure.ts",
    "db:load:local": "wrangler d1 execute freeside-adventure --local --file=db/adventure.sql",
    "db:load": "wrangler d1 execute freeside-adventure --remote --file=db/adventure.sql",
    "db:seed:local": "npm run build:adventure && npm run db:load:local",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run test && npm run test:e2e"
  },
  "dependencies": {
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.10",
    "@cloudflare/workers-types": "^4",
    "@playwright/test": "^1.60.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wrangler": "^4"
  }
}
